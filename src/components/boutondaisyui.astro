---
import "../styles/home.css";
import "../styles/page-transitions.css";
import "../styles/daisyui.css";
---

<div class="fixed bottom-6 right-6 z-[99]">
  <div class="fab fab-flower">
    <!-- Bouton principal focusable (requis pour tous les navigateurs) -->
    <div tabindex="0" role="button" class="btn btn-circle btn-lg">
      <svg
        aria-label="Nouveau"
        xmlns="http://www.w3.org/2000/svg"
        viewBox="0 0 16 16"
        fill="currentColor"
        class="size-6"
      >
        <path
          d="M8.75 3.75a.75.75 0 0 0-1.5 0v3.5h-3.5a.75.75 0 0 0 0 1.5h3.5v3.5a.75.75 0 0 0 1.5 0v-3.5h3.5a.75.75 0 0 0 0-1.5h-3.5v-3.5Z"
        />
      </svg>
    </div>

    <!-- Bouton principal (remplace l'icône + au clic) -->
    <button class="fab-main-action btn btn-circle btn-lg btn-primary">
      <svg
        aria-label="Nouveau post"
        xmlns="http://www.w3.org/2000/svg"
        viewBox="0 0 16 16"
        fill="currentColor"
        class="size-6"
      >
        <path
          fill-rule="evenodd"
          d="M11.013 2.513a1.75 1.75 0 0 1 2.475 2.474L6.226 12.25a2.751 2.751 0 0 1-.892.596l-2.047.848a.75.75 0 0 1-.98-.98l.848-2.047a2.75 2.75 0 0 1 .596-.892l7.262-7.261Z"
          clip-rule="evenodd"
        />
      </svg>
    </button>

    <!-- Boutons Speed Dial (4 max pour flower layout) -->
    <a 
  href="/Cv/cvFinal.pdf" 
  download 
  class="btn btn-circle btn-lg tooltip tooltip-left" 
  data-tip="Télécharger CV"
>
  <svg 
    xmlns="http://www.w3.org/2000/svg" 
    fill="none" 
    viewBox="0 0 24 24" 
    stroke-width="1.5" 
    stroke="currentColor" 
    class="size-6"
  >
    <path stroke-linecap="round" stroke-linejoin="round" d="M3 16.5v2.25A2.25 2.25 0 0 0 5.25 21h13.5A2.25 2.25 0 0 0 21 18.75V16.5M16.5 12 12 16.5m0 0L7.5 12m4.5 4.5V3" />
  </svg>
</a>

    <a 
    href="https://github.com/AxelEpi" 
    target="_blank" 
    class="btn btn-circle btn-lg tooltip tooltip-left" 
    data-tip="GitHub"
    >
    <svg width="36" height="36" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
  <g>
    <circle cx="12" cy="12" r="10.5" fill="#6C63FF"/>
    <path d="M12 7.5c-2.485 0-4.5 2.015-4.5 4.5 0 1.98 1.28 3.65 3.18 4.19.23.04.32-.1.32-.22v-.86c-1.29.28-1.56-.62-1.56-.62-.21-.54-.52-.68-.52-.68-.43-.29.03-.28.03-.28.48.03.74.5.74.5.42.72 1.1.51 1.37.39.04-.3.16-.51.29-.63-1.03-.12-2.12-.52-2.12-2.23 0-.49.17-.89.46-1.2-.05-.12-.2-.61.04-1.27 0 0 .39-.13 1.3.5.38-.11.78-.16 1.18-.16.4 0 .8.05 1.18.16.91-.63 1.3-.5 1.3-.5.24.66.09 1.15.04 1.27.29.31.46.71.46 1.2 0 1.71-1.09 2.11-2.13 2.23.17.15.32.44.32.89v1.32c0 .12.09.26.32.22C15.22 15.65 16.5 13.98 16.5 12c0-2.485-2.015-4.5-4.5-4.5z" fill="#fff"/>
  </g>
</svg> 
    </a>

   <a 
    href="/comments" 
    class="btn btn-circle btn-lg tooltip tooltip-left" 
    data-tip="Commentaires"
    >
    <svg 
        xmlns="http://www.w3.org/2000/svg" 
        fill="none" 
        viewBox="0 0 24 24" 
        stroke-width="1.5" 
        stroke="currentColor" 
        class="size-6"
    >
        <path stroke-linecap="round" stroke-linejoin="round" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z" />
    </svg>
    </a>
<a 
  href="/about" 
  class="btn btn-circle btn-lg tooltip tooltip-left" 
  data-tip="À propos"
>
  <svg xmlns="http://www.w3.org/2000/svg" 
  fill="none" 
  viewBox="0 0 24 24" 
  stroke-width="1.5" 
  stroke="currentColor" 
  class="size-6">
  <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 6a3.75 3.75 0 1 1-7.5 0 3.75 3.75 0 0 1 7.5 0ZM4.501 20.118a7.5 7.5 0 0 1 14.998 0A17.933 17.933 0 0 1 12 21.75c-2.676 0-5.216-.584-7.499-1.632Z" />
</svg>

</a>

  </div>
</div>